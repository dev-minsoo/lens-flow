{
  "name": "@dev-minsoo/lens-flow",
  "version": "1.0.2",
  "description": "Lens extension providing workload flow monitoring with React Flow",
  "main": "dist/main.js",
  "renderer": "dist/renderer.js",
  "homepage": "https://github.com/dev-minsoo/lens-flow",
  "publisher": "dev-minsoo",
  "license": "MIT",
  "keywords": [
    "lens",
    "openlens",
    "extension",
    "kubernetes",
    "react-flow",
    "topology"
  ],
  "engines": {
    "node": ">=16.14.0",
    "lens": "^6.0.0",
    "freelens": "^1.8.1"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "webpack --watch",
    "build": "npm run clean && webpack",
    "clean": "rm -rf ./dist",
    "prepack": "npm run build",
    "test": "rm -rf ./.test-dist && tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js && rm -rf ./.test-dist"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "reactflow": "^11.11.0"
  },
  "devDependencies": {
    "@k8slens/extensions": "^6.0.0",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.0.0",
    "@types/react": "^17.0.45",
    "@types/react-dom": "^17.0.16",
    "css-loader": "^6.8.1",
    "mobx": "^6.12.0",
    "mobx-react": "^7.6.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "sass": "^1.69.0",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
